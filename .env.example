# ============================================================================
# LLM-as-Judge Configuration (Captioning Evaluation)
# ============================================================================
# When configured, captioning evaluation will automatically use this model
# as the LLM judge to compute confusion matrix metrics (P/R/F1).
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env

# Model name for the LLM judge (e.g., gpt-4o-mini, gpt-4o, gemini-2.5-flash)
LLM_JUDGE_MODEL=gpt-4o-mini

# API key for the judge model
LLM_JUDGE_API_KEY=sk-your-api-key-here

# API base URL (default: OpenAI)
LLM_JUDGE_API_BASE=https://api.openai.com/v1
